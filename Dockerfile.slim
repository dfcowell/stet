# Slim image: ~5x smaller, no Chromium. Browser automation is disabled
# (STET_DISABLE_BROWSER=true), so gated / JS-rendered chapters surface a clear
# "needs a browser" error with an "open original" link instead of failing hard.
# Suitable for HTTP-only / server-rendered sources (e.g. AO3).
FROM node:24-bookworm AS builder
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends python3 make g++ \
    && rm -rf /var/lib/apt/lists/*
# We don't ship a browser in this image.
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
COPY package.json package-lock.json ./
RUN npm ci
COPY tsconfig.json ./
COPY src ./src
COPY test ./test
RUN npm run build

FROM node:24-bookworm-slim AS runtime
ENV NODE_ENV=production \
    PORT=8787 \
    STET_DISABLE_BROWSER=true \
    STET_WEB_DIR=/app/web \
    STET_CONFIG_DIR=/config \
    STET_DB_PATH=/data/stet.sqlite \
    STET_STATE_DIR=/data/state
WORKDIR /app
COPY package.json package-lock.json ./
COPY --from=builder /app/node_modules ./node_modules
RUN npm prune --omit=dev
COPY --from=builder /app/dist ./dist
COPY web ./web
COPY config /config
RUN mkdir -p /data && chown -R node:node /app /data /config
USER node
EXPOSE 8787
CMD ["node", "dist/src/index.js"]
